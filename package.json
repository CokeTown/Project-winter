{
  "name": "nine-winters",
  "private": true,
  "version": "1.9.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 8420 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 8420 --strictPort",
    "assets:tex": "node tools/gen-textures.mjs",
    "assets:models": "node tools/gen-models.mjs",
    "assets": "node tools/gen-textures.mjs && node tools/gen-models.mjs",
    "assets:icons": "node tools/gen-icons.mjs",
    "electron": "electron .",
    "build:electron": "vite build --mode electron",
    "build:exe": "npm run build:electron && electron-builder --win nsis portable",
    "test": "electron tests/core.test.cjs",
    "test:build": "vite build --mode electron && electron tests/core.test.cjs",
    "grounding": "electron tests/grounding/qa-systems.cjs && electron tests/grounding/qa-broad.cjs && electron tests/grounding/qa-breadth.cjs",
    "grounding:build": "vite build --mode electron && npm run grounding",
    "golden": "electron tests/grounding/golden.cjs",
    "golden:update": "electron tests/grounding/golden.cjs --update",
    "golden:build": "vite build --mode electron && npm run golden",
    "modal-golden": "electron tests/grounding/modal-golden.cjs",
    "modal-golden:update": "electron tests/grounding/modal-golden.cjs --update",
    "modal-golden:build": "vite build --mode electron && npm run modal-golden",
    "gates": "node tools/check-i18n.mjs && node tools/check-hardcode.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "steamworks.js": "^0.4.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "gif-encoder": "^0.7.2",
    "pngjs": "^7.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "build": {
    "appId": "com.projectwinter.shelter",
    "productName": "Nine Winters",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/steamworks.js/**"
    ],
    "extraResources": [
      {
        "from": "public/locales",
        "to": "locales"
      }
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "node_modules/steamworks.js/**"
    ]
  }
}
